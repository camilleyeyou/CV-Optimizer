# Block commits that contain .env files with secrets
ENV_FILES=$(git diff --cached --name-only | grep -E '\.env$|\.env\.' | grep -v '\.env\.example' || true)

if [ -n "$ENV_FILES" ]; then
  echo "ERROR: Attempting to commit .env files with potential secrets:"
  echo "$ENV_FILES"
  echo ""
  echo "Remove them from staging with: git reset HEAD <file>"
  exit 1
fi
