{
  "name": "cv-optimizer",
  "version": "1.0.0",
  "description": "A full-stack web application for creating ATS-optimized resumes with AI-powered suggestions and professional PDF export.",
  "main": "index.js",
  "scripts": {
    "build": "cd client && npm run build",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "cd client && npm start",
    "dev:server": "cd server && npm run dev",
    "start": "npm run dev",
    "test": "cd server && npx jest",
    "prepare": "husky || true"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/camilleyeyou/CV-Optimizer.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/camilleyeyou/CV-Optimizer/issues"
  },
  "homepage": "https://github.com/camilleyeyou/CV-Optimizer#readme",
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.6",
    "docx": "^9.6.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "openai": "^6.29.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.18.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  }
}
